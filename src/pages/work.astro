---
import Layout from '~/layouts/Layout.astro';
import { SITE } from '~/lib/site';

/* TODO(Will): walk this list and prune anything you wouldn't want to be
   asked about in a technical interview. The current list is what shows up
   across willyennie.com + your projects + likely Insight Designs work; some
   of it (Sidekiq, Redis, GraphQL, Stimulus, Astro, Vite) is plausible but
   not directly evidenced in the public sources. Cut what isn't real. */
const skills = {
  Languages: ['Ruby', 'TypeScript', 'JavaScript', 'SQL', 'Bash'],
  'Backend & data': ['Ruby on Rails', 'Sinatra', 'Node.js / Express', 'PostgreSQL', 'MongoDB', 'REST'],
  Frontend: ['React', 'Handlebars', 'ERB', 'CSS', 'Astro'],
  Infra: ['Docker', 'Terraform', 'AWS (Lambda, Kinesis Firehose, CloudWatch)', 'DigitalOcean', 'nginx'],
  Observability: ['OpenTelemetry', 'Grafana', 'Prometheus', 'Promscale / TimescaleDB'],
  Practice: ['TDD', 'systems design', 'mastery-based learning'],
};

type Role = {
  company: string;
  title: string;
  location: string;
  start: Date;
  end: Date | 'present';
  summary: string;
  bullets: string[];
  stack: string[];
  anchor: string;
};

const fmtDate = (d: Date | 'present') =>
  d === 'present'
    ? 'present'
    : d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });

/* Sources: LinkedIn (Insight Designs, Boulder CO, confirmed) + willyennie.com.
   Specific dates / job title / responsibilities are NOT publicly visible.
   Fill in from your own records. Do not invent. */
const roles: Role[] = [
  {
    company: 'Insight Designs Web Solutions',
    title: 'Software Engineer', // HR title was "Programmer"; function was software engineering.
    location: 'Boulder, CO (remote)',
    start: new Date(2025, 1), // February 2025
    end: new Date(2026, 3),   // April 2026
    summary:
      'Full-stack and infrastructure work for a Boulder-based web design consultancy with 600+ clients across its portfolio.',
    bullets: [
      'Worked across client websites for a consultancy with 600+ clients. Broad exposure to varied codebases, stacks, and product surfaces in a single role.',
      'Built out new client sites end-to-end, from spec through deploy.',
      'Owned ongoing maintenance and security updates across DigitalOcean-hosted production environments: the durable, behind-the-scenes work of keeping client sites running between feature engagements.',
    ],
    /* Stack inferred from Insight's published specialties (Certified Shopify
       Partner, "hundreds of custom WordPress site builds," Magento-certified
       developers) plus your explicit confirmation of building client sites
       and DigitalOcean server maintenance. TODO(Will): prune anything you
       didn't personally touch. */
    stack: ['Shopify / Liquid', 'WordPress / PHP', 'JavaScript', 'HTML / CSS', 'DigitalOcean'],
    anchor: 'insight',
  },
];

const education = [
  {
    name: 'Launch School',
    detail: 'Capstone graduate. Multi-year mastery-based program: fundamentals (OOP, data structures, networking, REST, databases) plus a capstone in advanced algorithms, system design, and just-in-time learning.',
    year: 2023, /* TODO(Will): real graduation year */
  },
];
---

<Layout title="work" description="Will Yennie résumé, roles, and stack." bodyClass="work-page">
  <article class="container resume">
    <header class="masthead">
      <div>
        <h1>Will Yennie</h1>
        <p class="subtitle">Full-stack engineer · Ruby on Rails · TypeScript · Postgres</p>
      </div>
      <ul class="contact">
        <li><a href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
        <li>{SITE.location}</li>
        <li><a href={SITE.linkedin}>linkedin.com/in/william-yennie</a></li>
        <li><a href={SITE.github}>{SITE.github.replace('https://', '')}</a></li>
      </ul>
    </header>

    <div class="print-hint no-print">
      <p>
        Want a PDF? <kbd>⌘</kbd> / <kbd>Ctrl</kbd> + <kbd>P</kbd> &rarr; <em>Save as PDF</em>.
        This page is print-styled.
      </p>
    </div>

    <section>
      <h2>Summary</h2>
      <p>
        Full-stack engineer focused on the durable, less-visible parts of web
        systems: data models, background jobs, the boundaries between
        services. Comfortable across Ruby on Rails, TypeScript, and SQL/NoSQL;
        recent work on serverless observability (Firefly) and AI integrations
        in developer tooling (ZenML).
      </p>
    </section>

    <section>
      <h2>Experience</h2>
      {roles.map((r) => (
        <article class="role" id={r.anchor}>
          <header class="role-head">
            <h3>{r.title} · <span class="company">{r.company}</span></h3>
            <span class="when">{fmtDate(r.start)} – {fmtDate(r.end)} · {r.location}</span>
          </header>
          <p class="role-summary">{r.summary}</p>
          <ul>
            {r.bullets.map((b) => <li>{b}</li>)}
          </ul>
          <p class="stack-line">
            <span class="lbl">stack:</span> {r.stack.join(' · ')}
          </p>
        </article>
      ))}
    </section>

    <section class="cols">
      <div>
        <h2>Skills</h2>
        <dl class="skills">
          {Object.entries(skills).map(([k, v]) => (
            <>
              <dt>{k}</dt>
              <dd>{v.join(', ')}</dd>
            </>
          ))}
        </dl>
      </div>

      <div>
        <h2>Education</h2>
        {education.map((e) => (
          <article class="edu">
            <h3>{e.name}</h3>
            <p>{e.detail}</p>
            <p class="when">{e.year}</p>
          </article>
        ))}
      </div>
    </section>

    <section>
      <h2>Selected projects</h2>
      <p class="muted">
        Full case studies at <a href="/projects">willyennie.dev/projects</a>.
      </p>
      <ul class="proj-line">
        <li><strong>Firefly</strong>: open-source observability framework for AWS Lambda. Node.js, OpenTelemetry, Promscale, Grafana. <em>Co-creator (4-person team).</em></li>
        <li><strong>Tabletop Ledger</strong>: solo-built campaign organizer for tabletop RPG game masters; tree of pages, WYSIWYG editor, context-aware AI chat with WebSocket streaming.</li>
        <li><strong>HookScope</strong>: webhook debugger; capture, inspect, and replay incoming webhooks against a local handler.</li>
        <li><strong>FlightWise / TaskVault / ShopSense</strong>: earlier full-stack work on flight visualization, task tracking, and e-commerce.</li>
      </ul>
    </section>
  </article>
</Layout>

<style>
  .resume {
    padding-block: var(--s-7) var(--s-8);
    max-width: 50rem;
  }
  .masthead {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-5);
    align-items: flex-start;
    justify-content: space-between;
    border-bottom: 1px solid var(--c-border);
    padding-bottom: var(--s-5);
    margin-bottom: var(--s-6);
  }
  .masthead h1 { font-size: var(--fs-2xl); }
  .subtitle {
    color: var(--c-text-muted);
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    margin-top: var(--s-2);
  }
  .contact {
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--c-text-muted);
    text-align: right;
    line-height: var(--lh-snug);
  }
  .print-hint {
    border: 1px dashed var(--c-border-strong);
    border-radius: var(--r-md);
    padding: var(--s-3) var(--s-4);
    margin-bottom: var(--s-6);
    color: var(--c-text-muted);
    font-size: var(--fs-sm);
  }

  section { margin-bottom: var(--s-7); }
  section > h2 {
    font-size: var(--fs-md);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-accent);
    border-bottom: 1px solid var(--c-border);
    padding-bottom: var(--s-2);
    margin-bottom: var(--s-4);
  }

  .role { margin-bottom: var(--s-6); }
  .role-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s-3);
  }
  .role-head h3 { font-size: var(--fs-md); }
  .company { color: var(--c-text-muted); font-weight: 400; }
  .when {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--c-text-muted);
  }
  .role-summary {
    margin-top: var(--s-2);
    color: var(--c-text-muted);
  }
  .role ul {
    margin-top: var(--s-2);
  }
  .role ul li { margin-bottom: var(--s-1); }
  .stack-line {
    margin-top: var(--s-3);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--c-text-dim);
  }
  .stack-line .lbl { color: var(--c-text-muted); }

  .cols {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--s-6);
  }
  @media (max-width: 640px) {
    .cols { grid-template-columns: 1fr; }
    .masthead { flex-direction: column; }
    .contact { text-align: left; }
  }
  .skills dt {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--c-text-muted);
    margin-top: var(--s-3);
  }
  .skills dd { margin-left: 0; }
  .skills dt:first-of-type { margin-top: 0; }

  .edu h3 { font-size: var(--fs-md); }
  .edu p { color: var(--c-text-muted); }

  .proj-line { padding-left: 1.25rem; }
  .proj-line li { margin-bottom: var(--s-2); }
  .muted { color: var(--c-text-muted); margin-bottom: var(--s-3); }

  /* Print refinements specific to this page */
  @media print {
    .resume { padding: 0; max-width: none; }
    section { margin-bottom: 1rem; page-break-inside: avoid; }
    .role { page-break-inside: avoid; margin-bottom: 0.8rem; }
    section > h2 {
      border-bottom: 1px solid #999;
      color: #000;
    }
  }
</style>
